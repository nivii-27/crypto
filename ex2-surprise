def sub_bytes(state):
    return [s + "_sub" for s in state]

def shift_rows(state):
    return [s + "_shift" for s in state]

def mix_columns(state):
    return [s + "_mixed" for s in state]

def add_round_key(state, key):
    return [f"{s}+{key}" for s in state]

def aes_round(state, round_key, is_final=False):
    state = sub_bytes(state)
    state = shift_rows(state)
    
    if not is_final:
        state = mix_columns(state)
        
    state = add_round_key(state, round_key)
    return state

initial_state = ["block1", "block2"]
round_keys = [f"Key{i}" for i in range(1, 11)]

round_9_result = aes_round(initial_state, round_keys[8], is_final=False)
print(f"Round 9 (Normal) Output: {round_9_result}")

round_10_result = aes_round(round_9_result, round_keys[9], is_final=True)
print(f"Round 10 (Final) Output: {round_10_result}")
